DB_HOST=localhost
DB_PORT=5432
DB_NAME=personal_ai_core
DB_USER=postgres
DB_PASSWORD=yourpassword

# LLM Provider: "google" (padrão) | "ollama" (local)
LLM_PROVIDER=google
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash

# Ollama local (LLM_PROVIDER=ollama)
# Instale: https://ollama.com | Execute: ollama serve && ollama pull llama3
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Chave de Encriptação (Obrigatória)
# Gere uma nova usando: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=sua_chave_aqui
