{
  "name": "personal-ai-core",
  "version": "1.0.0",
  "description": "Personal AI Core - Assistente Pessoal Modular",
  "scripts": {
    "test:backend": "python -m pytest app/tests --cov=app --cov-report=term-missing",
    "test:frontend": "cd web && npm test",
    "test:frontend:coverage": "cd web && npm run test -- --coverage",
    "test:report": "python scripts/test_report.py",
    "test": "npm run test:backend && npm run test:frontend",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "setup": "npm install && pip install -r requirements.txt && npm run db:up && npm run doctor",
    "doctor": "python scripts/doctor.py",
    "dev:backend": ".venv\\Scripts\\uvicorn.exe app.main:app --port 8000 --reload",
    "dev:frontend": "cd web && npm run dev"
  },
  "author": "Luis Marquitti",
  "license": "MIT"
}
